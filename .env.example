# ── Servidor (NUNCA usar prefijo NEXT_PUBLIC_; las claves se quedan en el server) ──

# Anthropic (Claude) — obligatoria
# https://console.anthropic.com → Settings → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxx

# CoinMarketCap Pro — obligatoria si querés usar CMC como fuente primaria
# https://pro.coinmarketcap.com → Dashboard → API Key
CMC_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Modelo de Claude. Dejar en sonnet-4-6 a menos que quieras cambiar.
ANTHROPIC_MODEL=claude-sonnet-4-6
